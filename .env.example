# API Keys — copy this file to .env and fill in your keys
# Never commit .env to git

OPENAI_API_KEY=sk-...
VOYAGE_API_KEY=pa-...
ANTHROPIC_API_KEY=sk-ant-...

# Optional — for Llama-3.1-8B generation via Groq
GROQ_API_KEY=gsk_...

# Optional — for GitHub CloudFormation ground truth collection
GITHUB_TOKEN=ghp_...

# Optional — HuggingFace token for SPLADE model
HF_TOKEN=hf_...
